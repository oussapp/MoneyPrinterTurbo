# ============================================================
# MoneyPrinterTurbo SaaS — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---------- Database ----------
DATABASE_URL=postgresql://mpt_user:mpt_pass@localhost:5432/moneyprinter
REDIS_URL=redis://localhost:6379/0

# ---------- Auth ----------
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# NextAuth (frontend)
NEXTAUTH_SECRET=change-me-also
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- Stripe ----------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_CREDITS_10=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...

# ---------- Storage ----------
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=moneyprinter-videos
S3_PUBLIC_URL=https://videos.yourdomain.com

# ---------- LLM (override config.toml) ----------
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# ---------- Stock Video ----------
PEXELS_API_KEY=
PIXABAY_API_KEY=

# ---------- Music ----------
JAMENDO_CLIENT_ID=

# ---------- TTS Premium ----------
ELEVENLABS_API_KEY=

# ---------- Monitoring ----------
SENTRY_DSN=
